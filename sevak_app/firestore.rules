rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ══════════════════════════════════════════════════════════════════════════
    // IMPORTANT: These rules require Firebase Custom Claims (role, ngoId).
    // Custom Claims must be set via Firebase Admin SDK / Cloud Functions.
    // DO NOT deploy until the Cloud Function is ready.
    // Currently running in TEST MODE — these rules are for documentation.
    // ══════════════════════════════════════════════════════════════════════════

    // Core helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }
    function belongsToNgo(ngoId) {
      return isAuthenticated() && request.auth.token.ngoId == ngoId;
    }
    
    // Role checks
    function isSuperAdmin() {
      return hasRole('SA');
    }
    function isNgoAdmin(ngoId) {
      return hasRole('NA') && belongsToNgo(ngoId);
    }
    function isCoordinator(ngoId) {
      return hasRole('CO') && belongsToNgo(ngoId);
    }
    function isVolunteer() {
      return hasRole('VL');
    }
    function isOwnDocument() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    // ── NGOs ─────────────────────────────────────────────────────────────────
    match /ngos/{ngoId} {
      // Anyone authenticated can READ active NGOs (for discovery page)
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Anyone can register (status: pending)
      allow delete: if isSuperAdmin();
      allow update: if isSuperAdmin() || isNgoAdmin(ngoId);
    }

    // ── Needs ────────────────────────────────────────────────────────────────
    match /needs/{needId} {
      allow create: if isAuthenticated();
      allow read: if (isAuthenticated() && resource.data.submittedBy == request.auth.uid) ||
                     isCoordinator(resource.data.ngoId) ||
                     isNgoAdmin(resource.data.ngoId) ||
                     isSuperAdmin() ||
                     (isVolunteer() && resource.data.assignedTo == request.auth.uid);
      allow update: if isCoordinator(resource.data.ngoId) || 
                       isNgoAdmin(resource.data.ngoId) ||
                       isSuperAdmin() ||
                       (isVolunteer() && resource.data.assignedTo == request.auth.uid) ||
                       (isAuthenticated() && resource.data.submittedBy == request.auth.uid);
      allow delete: if isNgoAdmin(resource.data.ngoId) || isCoordinator(resource.data.ngoId) || isSuperAdmin();
    }

    // ── Community Reports ────────────────────────────────────────────────────
    match /community_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read: if (isAuthenticated() && resource.data.submittedBy == request.auth.uid) ||
                     isCoordinator(resource.data.targetNgoId) ||
                     isNgoAdmin(resource.data.targetNgoId) ||
                     isSuperAdmin();
      allow update: if isCoordinator(resource.data.targetNgoId) || 
                       isNgoAdmin(resource.data.targetNgoId) ||
                       isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Volunteers ───────────────────────────────────────────────────────────
    match /volunteers/{userId} {
      allow read, update: if (isAuthenticated() && request.auth.uid == userId) || 
                              isNgoAdmin(resource.data.primaryNgoId) || 
                              isCoordinator(resource.data.primaryNgoId) ||
                              isSuperAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if (isAuthenticated() && request.auth.uid == userId) || 
                       isNgoAdmin(resource.data.primaryNgoId) ||
                       isSuperAdmin();
    }

    // ── NGO Invite Codes ─────────────────────────────────────────────────────
    match /ngoInvites/{code} {
      // Anyone authenticated can read (to verify codes)
      allow read: if isAuthenticated();
      // Only NA/SA can create invite codes
      allow create: if isSuperAdmin() || hasRole('NA');
      // Anyone can delete (single-use code consumed by volunteer)
      allow delete: if isAuthenticated();
      allow update: if isSuperAdmin() || hasRole('NA');
    }

    // ── Join Requests ────────────────────────────────────────────────────────
    match /joinRequests/{requestId} {
      // User can create their own join request
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // User can read their own requests, NGO admin can read requests for their NGO
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) ||
                     isNgoAdmin(resource.data.ngoId) ||
                     isSuperAdmin();
      // Only NGO admin or SA can update (approve/reject)
      allow update: if isNgoAdmin(resource.data.ngoId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ── Partnerships ─────────────────────────────────────────────────────────
    match /partnerships/{partnershipId} {
      allow read: if isSuperAdmin() || 
                     belongsToNgo(resource.data.ngoA) || 
                     belongsToNgo(resource.data.ngoB);
      allow create, update: if isNgoAdmin(request.resource.data.ngoA) || isNgoAdmin(request.resource.data.ngoB);
      allow delete: if isNgoAdmin(resource.data.ngoA) || isNgoAdmin(resource.data.ngoB) || isSuperAdmin();
    }

    // ── Cross-NGO Tasks ──────────────────────────────────────────────────────
    match /crossNgoTasks/{taskId} {
      allow read: if isSuperAdmin() || 
                     belongsToNgo(resource.data.sourceNgoId) || 
                     belongsToNgo(resource.data.volunteerNgoId) ||
                     (isVolunteer() && resource.data.volunteerUid == request.auth.uid);
      allow create, update: if isCoordinator(request.resource.data.sourceNgoId) || 
                               isCoordinator(request.resource.data.volunteerNgoId) ||
                               (isVolunteer() && resource.data.volunteerUid == request.auth.uid);
    }

    // ── Platform Config ──────────────────────────────────────────────────────
    match /platformConfig/{docId} {
      allow read: if isAuthenticated(); // SA list readable to check SA status
      allow write: if isSuperAdmin();
    }

    // ── Platform Metrics ─────────────────────────────────────────────────────
    match /platformMetrics/{metricId} {
      allow read: if isSuperAdmin();
      allow write: if false; // Only via Cloud Functions
    }
  }
}
